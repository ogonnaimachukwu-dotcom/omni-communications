# ---- Core ----
NODE_ENV=production
APP_URL=https://omni.example.com

# ---- Database (shared by Drizzle + pg-boss) ----
DATABASE_URL=postgres://omni:omni@db:5432/omni

# ---- Better Auth ----
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me
BETTER_AUTH_URL=https://omni.example.com

# ---- Secret encryption (AES-256-GCM master key, 32 bytes base64) ----
# Generate: openssl rand -base64 32
ENCRYPTION_MASTER_KEY=replace-me

# ---- Resend (platform sending key for Phase 1) ----
RESEND_API_KEY=re_replace_me
RESEND_WEBHOOK_SECRET=whsec_replace_me

# ---- AI drafting (Anthropic Claude) ----
ANTHROPIC_API_KEY=sk-ant-replace-me

# ---- OAuth Credentials (Phase 2 Mailbox Connections) ----
GOOGLE_CLIENT_ID=google-client-id
GOOGLE_CLIENT_SECRET=google-client-secret
MICROSOFT_CLIENT_ID=microsoft-client-id
MICROSOFT_CLIENT_SECRET=microsoft-client-secret
